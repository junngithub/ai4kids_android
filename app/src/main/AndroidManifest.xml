<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The four core activities play fully offline. The online "Brain Arcade"
         card games talk to the ai4kids backend, so internet access is needed. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AI4Kids">

        <!-- Handle rotation ourselves so Compose just relayouts (rather than the
             Activity being recreated, which would reset the open screen). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|uiMode|density|navigation"
            android:theme="@style/Theme.AI4Kids">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LibGDX Escape Room game (its own AndroidApplication surface).
             Plays in either orientation: the FitViewport keeps the world
             correctly proportioned and re-centres it on rotation (see
             EscapeGdxGame.resize), so landscape letterboxes rather than
             distorting, and touch math stays valid via viewport.unproject. -->
        <activity
            android:name=".gdx.EscapeActivity"
            android:exported="false"
            android:screenOrientation="fullUser"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenSize|screenLayout|smallestScreenSize|uiMode|density"
            android:theme="@style/Theme.AI4Kids" />
    </application>

</manifest>
